# Example environment — safe to commit. Copy to .env and fill real values.
#
# The DEMO runs with a mock LLM and needs NONE of these. They are listed only
# to show where a real deployment would plug in credentials — through the
# governance boundary (src/governance/aiBoundary.ts), never anywhere else.

# Only the governance boundary reads this. No other file imports the SDK.
ANTHROPIC_API_KEY=

# Model + runtime config, centralized at the boundary.
LLM_MODEL=claude-sonnet-4-5
APP_ENV=development
